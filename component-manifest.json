{
  "version": "1.0.0",
  "remotes": {
    "config": {
      "github": "git@github.com:Mixiaomiupup/claude-config.git",
      "yunxiao": "git@codeup.aliyun.com:696f3f56b28d0aba0f5e4371/Common-Components/claude_config.git"
    },
    "skills": {
      "github": "git@github.com:Mixiaomiupup/claude-skills.git",
      "yunxiao": "git@codeup.aliyun.com:696f3f56b28d0aba0f5e4371/Common-Components/claude_skills.git"
    }
  },
  "skills": {
    "first-party": [
      "commit",
      "debug",
      "doc-control",
      "explain",
      "gemini-image",
      "kb",
      "python-style",
      "refactor",
      "remote-repos",
      "review",
      "server",
      "sync-config",
      "test",
      "ucal",
      "x2md",
      "feishu",
      "cover-image"
    ],
    "third-party": {
      "baoyu-skills": {
        "url": "https://github.com/jimliu/baoyu-skills.git",
        "branch": "main"
      }
    }
  },
  "sanitize": {
    "settings.json": {
      "replace_env_keys": [
        "ANTHROPIC_AUTH_TOKEN"
      ],
      "strip_fields": [
        "model"
      ]
    },
    "skills/gemini-image/SKILL.md": {
      "patterns": [
        [
          "uxfv3f-ogqz-cc08ce285c88\\.json",
          "YOUR_SERVICE_ACCOUNT_FILE"
        ],
        [
          "uxfv3f-ogqz",
          "YOUR_GCP_PROJECT"
        ]
      ]
    },
    "mcp-servers.json": {
      "env_keys": {
        "tavily": [
          "TAVILY_API_KEY"
        ],
        "yunxiao": [
          "YUNXIAO_ACCESS_TOKEN"
        ]
      },
      "args_secrets": {
        "lark-mcp": [
          {
            "after_flag": "-a",
            "placeholder": "YOUR_LARK_APP_ID"
          },
          {
            "after_flag": "-s",
            "placeholder": "YOUR_LARK_APP_SECRET"
          }
        ]
      },
      "path_normalize": [
        "ucal"
      ]
    },
    "skills/server/SKILL.md": {
      "patterns": [
        [
          "mi954993689\\.\\.",
          "YOUR_PASSWORD_HERE"
        ],
        [
          "106\\.15\\.125\\.84",
          "YOUR_SERVER_IP"
        ],
        [
          "172\\.24\\.17\\.232",
          "YOUR_PRIVATE_IP"
        ]
      ]
    }
  }
}
