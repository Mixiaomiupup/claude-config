{
  "tavily": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "tavily-mcp@latest"
    ],
    "env": {
      "TAVILY_API_KEY": "YOUR_TAVILY_API_KEY_HERE"
    }
  },
  "ucal": {
    "type": "stdio",
    "command": "$HOME/.local/bin/uv",
    "args": [
      "run",
      "--directory",
      "$HOME/projects/ucal",
      "ucal"
    ],
    "env": {}
  },
  "lark-mcp": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "@larksuiteoapi/lark-mcp",
      "mcp",
      "-a",
      "YOUR_LARK_APP_ID",
      "-s",
      "YOUR_LARK_APP_SECRET",
      "--token-mode",
      "tenant_access_token"
    ],
    "env": {}
  },
  "yunxiao": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "alibabacloud-devops-mcp-server"
    ],
    "env": {
      "YUNXIAO_ACCESS_TOKEN": "YOUR_YUNXIAO_ACCESS_TOKEN_HERE"
    }
  }
}
